const API_ROOT = "https://v3.football.api-sports.io";
const WORLD_CUP_LEAGUE_ID = 1;
const WORLD_CUP_SEASON = 2026;

const LIVE_STATUS_CODES = new Set(["1H", "HT", "2H", "ET", "BT", "P", "LIVE", "SUSP", "INT"]);
const FINISHED_STATUS_CODES = new Set(["FT", "AET", "PEN"]);
const POSTPONED_STATUS_CODES = new Set(["PST", "CANC", "ABD", "AWD", "WO"]);

const FLAG_BY_NAME = new Map(Object.entries({
  "Argentina": "🇦🇷", "Algeria": "🇩🇿", "Austria": "🇦🇹", "Jordan": "🇯🇴",
  "Ghana": "🇬🇭", "Panama": "🇵🇦", "England": "🏴", "Croatia": "🇭🇷",
  "Portugal": "🇵🇹", "DR Congo": "🇨🇩", "Congo DR": "🇨🇩", "Uzbekistan": "🇺🇿",
  "Colombia": "🇨🇴", "Czech Republic": "🇨🇿", "Czechia": "🇨🇿", "South Africa": "🇿🇦",
  "Switzerland": "🇨🇭", "South Korea": "🇰🇷", "Korea Republic": "🇰🇷", "USA": "🇺🇸",
  "United States": "🇺🇸", "Australia": "🇦🇺", "Mexico": "🇲🇽", "Canada": "🇨🇦",
  "Bosnia & Herzegovina": "🇧🇦", "Bosnia and Herzegovina": "🇧🇦", "Qatar": "🇶🇦",
  "Brazil": "🇧🇷", "France": "🇫🇷", "Germany": "🇩🇪", "Spain": "🇪🇸",
  "Norway": "🇳🇴", "Morocco": "🇲🇦", "Senegal": "🇸🇳", "Belgium": "🇧🇪",
  "Egypt": "🇪🇬", "Uruguay": "🇺🇾", "New Zealand": "🇳🇿", "Japan": "🇯🇵",
  "Tunisia": "🇹🇳", "Ecuador": "🇪🇨", "Iran": "🇮🇷", "Saudi Arabia": "🇸🇦",
  "Ivory Coast": "🇨🇮", "Côte d'Ivoire": "🇨🇮", "Cape Verde": "🇨🇻", "Paraguay": "🇵🇾",
  "Scotland": "🏴", "Haiti": "🇭🇹", "Curacao": "🇨🇼", "Curaçao": "🇨🇼",
  "Costa Rica": "🇨🇷", "Jamaica": "🇯🇲", "Cameroon": "🇨🇲", "Nigeria": "🇳🇬",
